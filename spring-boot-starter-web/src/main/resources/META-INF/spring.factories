# Auto Configure
org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
io.springperf.web.autoconfigure.PerfAutoConfiguration,\
io.springperf.web.autoconfigure.PerfSupportAutoConfiguration,\
io.springperf.web.autoconfigure.PerfEndpointAutoConfiguration
org.springframework.boot.ApplicationContextFactory=\
io.springperf.web.autoconfigure.support.WebServerApplicationContextFactory