      "sourceType": "io.springperf.web.context.ApplicationProperties",
      "defaultValue": 50
    },
    {
      "name": "pool.max-pool-size",
      "type": "java.lang.Integer",
      "description": "Default business thread pool max pool size.",
      "sourceType": "io.springperf.web.context.ApplicationProperties",
      "defaultValue": 200
    },
    {
      "name": "pool.keep-alive-time",
      "type": "java.lang.Integer",
      "description": "Business thread pool thread keep-alive time in seconds.",
      "sourceType": "io.springperf.web.context.ApplicationProperties",
      "defaultValue": 60
    },
    {
      "name": "pool.queue-capacity",
      "type": "java.lang.Integer",
      "description": "Business thread pool queue capacity (unbounded if not set).",
      "sourceType": "io.springperf.web.context.ApplicationProperties",
      "defaultValue": "Integer.MAX_VALUE"
